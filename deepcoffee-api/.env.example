DEEPCOFFEE_APP_ENV=local
DEEPCOFFEE_BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Optional for local development. Defaults to ../knowledge from this repo.
# DEEPCOFFEE_KNOWLEDGE_DIR=../knowledge

# Supabase / PostgreSQL
SUPABASE_URL=
SUPABASE_JWT_SECRET=
DATABASE_URL=

# OpenAI-compatible model gateway. User quota is managed by DeepCoffee.
DEEPCOFFEE_MODEL_BASE_URL=
DEEPCOFFEE_MODEL_API_KEY=
DEEPCOFFEE_MODEL_DEFAULT_MODEL=deepseek-v4-pro

# Optional independent vision gateway. Leave empty to disable image understanding.
DEEPCOFFEE_VISION_MODEL_BASE_URL=
DEEPCOFFEE_VISION_MODEL_API_KEY=
DEEPCOFFEE_VISION_MODEL=kimi-k2.6

# 联网核实 web_verify（§9）：Brave Search API key。留空则 web_verify 降级回本地知识库。
BRAVE_API_KEY=

# Observability
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
DEEPCOFFEE_LOG_FULL_AI_IO=false

# Comma-separated Supabase user ids with admin access (兜底名单，可留空).
DEEPCOFFEE_ADMIN_USER_IDS=

# Payment providers. Leave empty until merchant accounts are ready; payment
# routes will return provider-not-configured errors instead of breaking startup.
DEEPCOFFEE_FRONTEND_PUBLIC_URL=http://localhost:3000
DEEPCOFFEE_BACKEND_PUBLIC_URL=http://localhost:8642
DEEPCOFFEE_ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
DEEPCOFFEE_ALIPAY_APP_ID=
DEEPCOFFEE_ALIPAY_APP_PRIVATE_KEY=
DEEPCOFFEE_ALIPAY_PUBLIC_KEY=
DEEPCOFFEE_ALIPAY_SELLER_ID=
DEEPCOFFEE_ALIPAY_NOTIFY_URL=
DEEPCOFFEE_ALIPAY_ORDER_TTL_MINUTES=15
DEEPCOFFEE_STRIPE_SECRET_KEY=
DEEPCOFFEE_STRIPE_WEBHOOK_SECRET=
DEEPCOFFEE_STRIPE_PRICE_PRO_MONTHLY=
DEEPCOFFEE_STRIPE_PRICE_PRO_YEARLY=
DEEPCOFFEE_STRIPE_PRICE_MAX_MONTHLY=
DEEPCOFFEE_STRIPE_PRICE_MAX_YEARLY=

# 初始化邀请码（首个管理员引导）：部署时用 deploy/gen-bootstrap-code.sh 随机生成。
# 仅当数据库里还没有任何 admin 时，启动会把它注册为一次性邀请码；用它注册的
# 用户 user_profiles.role 自动置为 admin。初始化完成后此配置自动失效。
# 注意：user_profiles 表是已有表，部署前需在 Supabase 手动执行：
#   ALTER TABLE user_profiles ADD COLUMN IF NOT EXISTS role text NOT NULL DEFAULT 'user';
DEEPCOFFEE_BOOTSTRAP_INVITE_CODE=
