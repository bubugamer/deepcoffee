DEEPCOFFEE_APP_ENV=local
DEEPCOFFEE_BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Optional for local development. Defaults to ../knowledge from this repo.
# DEEPCOFFEE_KNOWLEDGE_DIR=../knowledge

# Supabase / PostgreSQL
SUPABASE_URL=
SUPABASE_JWT_SECRET=
DATABASE_URL=

# new-api model gateway
NEW_API_BASE_URL=
NEW_API_ADMIN_TOKEN=
# 新用户影子账户初始额度（内部单位，500000 = $1；$20 = 10000000）。
# 只在影子账户创建时授一次；存量用户改额度去 new-api 控制台手动调。
NEW_API_INITIAL_QUOTA=10000000

# 联网核实 web_verify（§9）：Brave Search API key。留空则 web_verify 降级回本地知识库。
BRAVE_API_KEY=

# Observability
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
DEEPCOFFEE_LOG_FULL_AI_IO=false

# Comma-separated Supabase user ids with admin access (兜底名单，可留空).
DEEPCOFFEE_ADMIN_USER_IDS=

# 初始化邀请码（首个管理员引导）：部署时用 deploy/gen-bootstrap-code.sh 随机生成。
# 仅当数据库里还没有任何 admin 时，启动会把它注册为一次性邀请码；用它注册的
# 用户 user_profiles.role 自动置为 admin。初始化完成后此配置自动失效。
# 注意：user_profiles 表是已有表，部署前需在 Supabase 手动执行：
#   ALTER TABLE user_profiles ADD COLUMN IF NOT EXISTS role text NOT NULL DEFAULT 'user';
DEEPCOFFEE_BOOTSTRAP_INVITE_CODE=
